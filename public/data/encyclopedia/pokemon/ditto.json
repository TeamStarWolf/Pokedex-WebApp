age": "en"}, {"gameVersionId": "game:black", "text": "It has the ability to reconstitute its entire cellular structure to transform into whatever it sees.", "language": "en"}, {"gameVersionId": "game:black-2", "text": "It can reconstitute its entire cellular structure to change into what it sees, but it returns to normal when it relaxes.", "language": "en"}, {"gameVersionId": "game:blue", "text": "Capable of copying an enemy's genetic code to instantly transform itself into a duplicate of the enemy.", "language": "en"}, {"gameVersionId": "game:crystal", "text": "When it encount\u00ad ers another DITTO, it will move faster than normal to duplicate that opponent exactly.", "language": "en"}, {"gameVersionId": "game:diamond", "text": "It has the ability to reconstitute its entire cellular structure to transform into whatever it sees.", "language": "en"}, {"gameVersionId": "game:emerald", "text": "A DITTO rearranges its cell structure to transform itself. However, if it tries to change based on its memory, it will get details wrong.", "language": "en"}, {"gameVersionId": "game:firered", "text": "It can freely recombine its own cellular structure to transform into other life- forms.", "language": "en"}, {"gameVersionId": "game:gold", "text": "It can transform into anything. When it sleeps, it changes into a stone to avoid being attacked.", "language": "en"}, {"gameVersionId": "game:heartgold", "text": "It can transform into anything. When it sleeps, it changes into a stone to avoid being attacked.", "language": "en"}, {"gameVersionId": "game:leafgreen", "text": "Capable of copying an opponent\u2019s genetic code to instantly transform itself into a duplicate of the enemy.", "language": "en"}, {"gameVersionId": "game:lets-go-eevee", "text": "When it spots an enemy, its body transfigures into an almost-perfect copy of its opponent.", "language": "en"}, {"gameVersionId": "game:lets-go-pikachu", "text": "When it spots an enemy, its body transfigures into an almost-perfect copy of its opponent.", "language": "en"}, {"gameVersionId": "game:moon", "text": "With its astonishing capacity for metamorphosis, it can get along with anything. It does not get along well with its fellow Ditto.", "language": "en"}, {"gameVersionId": "game:omega-ruby", "text": "Ditto rearranges its cell structure to transform itself into other shapes. However, if it tries to transform itself into something by relying on its memory, this Pok\u00e9mon manages to get details wrong.", "language": "en"}, {"gameVersionId": "game:pearl", "text": "It has the ability to reconstitute its entire cellular structure to transform into whatever it sees.", "language": "en"}, {"gameVersionId": "game:platinum", "text": "It has the ability to reconstitute its entire cellular structure to transform into whatever it sees.", "language": "en"}, {"gameVersionId": "game:red", "text": "Capable of copying an enemy's genetic code to instantly transform itself into a duplicate of the enemy.", "language": "en"}, {"gameVersionId": "game:ruby", "text": "DITTO rearranges its cell structure to transform itself into other shapes. However, if it tries to transform itself into something by relying on its memory, this POK\u00e9MON manages to get details wrong.", "language": "en"}, {"gameVersionId": "game:sapphire", "text": "DITTO rearranges its cell structure to transform itself into other shapes. However, if it tries to transform itself into something by relying on its memory, this POK\u00e9MON manages to get details wrong.", "language": "en"}, {"gameVersionId": "game:shield", "text": "When it encounters another Ditto, it will move faster than normal to duplicate that opponent exactly.", "language": "en"}, {"gameVersionId": "game:silver", "text": "Its transformation ability is per\u00ad fect. However, if made to laugh, it can't maintain its disguise.", "language": "en"}, {"gameVersionId": "game:soulsilver", "text": "Its transformation ability is perfect. However, if made to laugh, it can\u2019t maintain its disguise.", "language": "en"}, {"gameVersionId": "game:sun", "text": "It can reorganize its cells to make itself into a duplicate of anything it sees. The quality of the duplicate depends on the individual.", "language": "en"}, {"gameVersionId": "game:sword", "text": "It can reconstitute its entire cellular structure to change into what it sees, but it returns to normal when it relaxes.", "language": "en"}, {"gameVersionId": "game:ultra-moon", "text": "It transforms into whatever it sees. If the thing it\u2019s transforming into isn\u2019t right in front of it, Ditto relies on its memory\u2014so sometimes it fails.", "language": "en"}, {"gameVersionId": "game:ultra-sun", "text": "While it can transform into anything, each Ditto apparently has its own strengths and weaknesses when it comes to transformations.", "language": "en"}, {"gameVersionId": "game:white", "text": "It has the ability to reconstitute its entire cellular structure to transform into whatever it sees.", "language": "en"}, {"gameVersionId": "game:white-2", "text": "It can reconstitute its entire cellular structure to change into what it sees, but it returns to normal when it relaxes.", "language": "en"}, {"gameVersionId": "game:x", "text": "It has the ability to reconstitute its entire cellular structure to transform into whatever it sees.", "language": "en"}, {"gameVersionId": "game:y", "text": "It can freely recombine its own cellular structure to transform into other life-forms.", "language": "en"}, {"gameVersionId": "game:yellow", "text": "When it spots an enemy, its body transfigures into an almost perfect copy of its oppo\u00ad nent.", "language": "en"}], "locationIds": [], "competitiveSummary": ["Competitive notes are pending a richer source import."], "loreSummary": ["Ditto rearranges its cell structure to transform itself into other shapes. However, if it tries to transform itself into something by relying on its memory, this Pok\u00e9mon manages to get details wrong.", "Common habitat