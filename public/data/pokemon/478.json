, "value": 120}], "baseStatTotal": 580, "height": 2.6, "weight": 29.6, "moveCount": 0, "availableVersionGroups": [], "versionGroupMoves": {}}], "defaultFormId": 478, "versionEntries": [{"version": "alpha-sapphire", "text": "Legends in snowy regions say that a woman who was lost on an icy mountain was reborn as Froslass."}, {"version": "black", "text": "It freezes prey by blowing its -58 degrees F breath. It is said to then secretly display its prey."}, {"version": "black-2", "text": "It freezes prey by blowing its -58 degrees F breath. It is said to then secretly display its prey."}, {"version": "diamond", "text": "It freezes foes with an icy breath nearly -60 degrees F. What seems to be its body is actually hollow."}, {"version": "heartgold", "text": "Legends in snowy regions say that a woman who was lost on an icy mountain was reborn as FROSLASS."}, {"version": "legends-arceus", "text": "A Pok\u00e9mon inhabited by the soul of a woman who died bearing a grudge in the snowy mountains. Legends of Froslass placing deathly curses on misbehaving men send shivers down my spine."}, {"version": "moon", "text": "The soul of a woman lost on a snowy mountain possessed an icicle, becoming this Pok\u00e9mon. The food it most relishes is the souls of men."}, {"version": "omega-ruby", "text": "It freezes foes with an icy breath nearly -60 degrees Fahrenheit. What seems to be its body is actually hollow."}, {"version": "pearl", "text": "It freezes foes with an icy breath nearly -60 degrees F. What seems to be its body is actually hollow."}, {"version": "platinum", "text": "It freezes prey by blowing its -58 degrees F breath. It is said to then secretly display its prey."}, {"version": "shield", "text": "It spits out cold air of nearly \u221260 degrees Fahrenheit to freeze its quarry. It brings frozen prey back to its lair and neatly lines them up."}, {"version": "soulsilver", "text": "Legends in snowy regions say that a woman who was lost on an icy mountain was reborn as FROSLASS"}, {"version": "sun", "text": "When it finds humans or Pok\u00e9mon it likes, it freezes them and takes them to its chilly den, where they become decorations."}, {"version": "sword", "text": "After a woman met her end on a snowy mountain, her regrets lingered on. From them, this Pok\u00e9mon was born. Its favorite food is frozen souls."}, {"version": "ultra-moon", "text": "It\u2019s said that on nights of terrible blizzards, it comes down to human settlements. If you hear it knocking at your door, do not open it!"}, {"version": "ultra-sun", "text": "It freezes hikers who have come to climb snowy mountains and carries them back to its home. It only goes after men it thinks are handsome."}, {"version": "white", "text": "It freezes prey by blowing its -58 degrees F breath. It is said to then secretly display its prey."}, {"version": "white-2", "text": "It freezes prey by blowing its -58 degrees F breath. It is said to then secretly display its prey."}, {"version": "x", "text": "It freezes foes with an icy breath nearly -60 degrees Fahrenheit. What seems to be its body is actually hollow."}, {"version": "y", "text": "Legends in snowy regions say that a woman who was lost on an icy mountain was reborn as Froslass."}], "entryGameVersions": ["alpha-sapphire", "black", "black-2", "diamond", "heartgold", "legends-arceus", "moon", "omega-ruby", "pearl", "platinum", "shield", "soulsilver", "sun", "sword", "ultra-moon", "ultra-sun", "white", "white-2", "x", "y"], "moveGameGroups": ["black-2-white-2", "black-white", "brilliant-diamond-shining-pearl", "diamond-pearl", "heartgold-soulsilver", "legends-arceus", "omega-ruby-alpha-sapphire", "platinum", "scarlet-violet", "sun-moon", "sword-shield", "ultra-sun-ultra-moon", "x-y"], "evolutionRows": [{"stage": 1, "name": "snorunt"}, {"stage": 2, "name": "froslass"}, {"stage": 2, "name": "glalie"}]}