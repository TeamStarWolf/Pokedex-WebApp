outrage", "method": "level-up", "level": 53}]}}, {"id": 10302, "speciesId": 780, "name": "drampa-mega", "image": "/official-artwork/10302.png", "isDefault": false, "tag": "Mega", "formFamily": "Mega", "types": ["normal", "dragon"], "abilities": [], "stats": [{"name": "hp", "value": 78}, {"name": "attack", "value": 85}, {"name": "defense", "value": 110}, {"name": "special-attack", "value": 160}, {"name": "special-defense", "value": 116}, {"name": "speed", "value": 36}], "baseStatTotal": 585, "height": 3.0, "weight": 240.5, "moveCount": 0, "availableVersionGroups": [], "versionGroupMoves": {}}], "defaultFormId": 780, "versionEntries": [{"version": "moon", "text": "This Pok\u00e9mon is friendly to people and loves children most of all. It comes from deep in the mountains to play with children it likes in town."}, {"version": "shield", "text": "Drampa is a kind and friendly Pok\u00e9mon\u2014up until it\u2019s angered. When that happens, it stirs up a gale and flattens everything around."}, {"version": "sun", "text": "It has a compassionate personality, but if it is angered, it completely destroys its surroundings with its intense breath."}, {"version": "sword", "text": "The mountains it calls home are nearly two miles in height. On rare occasions, it descends to play with the children living in the towns below."}, {"version": "ultra-moon", "text": "It appears in towns and plays with the children. Drampa will protect kids when they\u2019re in danger, so their moms don\u2019t have to worry."}, {"version": "ultra-sun", "text": "If a child it has made friends with is bullied, Drampa will find the bully\u2019s house and burn it to the ground."}], "entryGameVersions": ["moon", "shield", "sun", "sword", "ultra-moon", "ultra-sun"], "moveGameGroups": ["sun-moon", "sword-shield", "ultra-sun-ultra-moon"], "evolutionRows": [{"stage": 1, "name": "drampa"}]}