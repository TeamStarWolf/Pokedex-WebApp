": {}}], "defaultFormId": 701, "versionEntries": [{"version": "alpha-sapphire", "text": "With its wings, it controls its position in the air. It likes to attack from above, a maneuver that is difficult to defend against."}, {"version": "omega-ruby", "text": "Although its body is small, its proficient fighting skills enable it to keep up with big bruisers like Machamp and Hariyama."}, {"version": "shield", "text": "It always strikes a pose before going for its finishing move. Sometimes opponents take advantage of that time to counterattack."}, {"version": "sword", "text": "It drives its opponents to exhaustion with its agile maneuvers, then ends the fight with a flashy finishing move."}, {"version": "ultra-moon", "text": "In combat, Hawlucha leaps nimbly about, taking advantage of its opponents\u2019 blind spots. It\u2019s also skilled at using superb submission holds."}, {"version": "ultra-sun", "text": "It overwhelms opponents with quick moves, but sometimes it showboats for too long when it\u2019s using a special move and gets itself into a pinch."}, {"version": "x", "text": "Although its body is small, its proficient fighting skills enable it to keep up with big bruisers like Machamp and Hariyama."}, {"version": "y", "text": "With its wings, it controls its position in the air. It likes to attack from above, a maneuver that is difficult to defend against."}], "entryGameVersions": ["alpha-sapphire", "omega-ruby", "shield", "sword", "ultra-moon", "ultra-sun", "x", "y"], "moveGameGroups": ["omega-ruby-alpha-sapphire", "scarlet-violet", "sun-moon", "sword-shield", "ultra-sun-ultra-moon", "x-y"], "evolutionRows": [{"stage": 1, "name": "hawlucha"}]}