 "method": "tutor", "level": 0}, {"move": "shadow-ball", "method": "machine", "level": 0}, {"move": "shock-wave", "method": "machine", "level": 0}, {"move": "solar-beam", "method": "machine", "level": 0}, {"move": "substitute", "method": "tutor", "level": 0}, {"move": "sunny-day", "method": "machine", "level": 0}, {"move": "swagger", "method": "tutor", "level": 0}, {"move": "toxic", "method": "machine", "level": 0}, {"move": "water-pulse", "method": "machine", "level": 0}, {"move": "pound", "method": "level-up", "level": 1}, {"move": "uproar", "method": "level-up", "level": 5}, {"move": "astonish", "method": "level-up", "level": 11}, {"move": "howl", "method": "level-up", "level": 15}, {"move": "supersonic", "method": "level-up", "level": 21}, {"move": "stomp", "method": "level-up", "level": 25}, {"move": "screech", "method": "level-up", "level": 31}, {"move": "roar", "method": "level-up", "level": 35}, {"move": "rest", "method": "level-up", "level": 41}, {"move": "sleep-talk", "method": "level-up", "level": 41}, {"move": "hyper-voice", "method": "level-up", "level": 45}]}}], "defaultFormId": 293, "versionEntries": [{"version": "alpha-sapphire", "text": "Whismur is very timid. If it starts to cry loudly, it becomes startled by its own crying and cries even harder. When it finally stops crying, the Pok\u00e9mon goes to sleep, all tired out."}, {"version": "black", "text": "Usually, its cries are like quiet murmurs. If frightened, it shrieks at the same volume as a jet plane."}, {"version": "black-2", "text": "Usually, its cries are like quiet murmurs. If frightened, it shrieks at the same volume as a jet plane."}, {"version": "diamond", "text": "Usually, its cries are like quiet murmurs. If frightened, it shrieks at the same volume as a jet plane."}, {"version": "emerald", "text": "Its cries equal a jet plane in volume. It inhales through its ear canals. Because of this system, it can cry continually without having to catch its breath."}, {"version": "firered", "text": "It usually murmurs, but starts crying loudly if it senses danger. It stops when its ear covers are shut."}, {"version": "heartgold", "text": "If it senses danger, it scares the foe by crying out with the volume of a jet-plane engine."}, {"version": "leafgreen", "text": "It usually murmurs, but starts crying loudly if it senses danger. It stops when its ear covers are shut."}, {"version": "omega-ruby", "text": "Normally, Whismur\u2019s voice is very quiet\u2014it is barely audible even if one is paying close attention. However, if this Pok\u00e9mon senses danger, it starts crying at an earsplitting volume."}, {"version": "pearl", "text": "Usually, its cries are like quiet murmurs. If frightened, it shrieks at the same volume as a jet plane."}, {"version": "platinum", "text": "Usually, its cries are like quiet murmurs. If frightened, it shrieks at the same volume as a jet plane."}, {"version": "ruby", "text": "Normally, WHISMUR\u2019s voice is very quiet - it is barely audible even if one is paying close attention. However, if this POK\u00e9MON senses danger, it starts crying at an earsplitting volume."}, {"version": "sapphire", "text": "WHISMUR is very timid. If it starts to cry loudly, it becomes startled by its own crying and cries even harder. When it finally stops crying, the POK\u00e9MON goes to sleep, all tired out."}, {"version": "shield", "text": "When Whismur cries, the sound of its own voice startles it, making the Pok\u00e9mon cry even louder. It cries until it\u2019s exhausted, then it falls asleep."}, {"version": "soulsilver", "text": "If it senses danger, it scares the foe by crying out with the volume of a jet-plane engine."}, {"version": "sword", "text": "The cry of a Whismur is over 100 decibels. If you\u2019re close to a Whismur when it lets out a cry, you\u2019ll be stuck with an all-day headache."}, {"version": "white", "text": "Usually, its cries are like quiet murmurs. If frightened, it shrieks at the same volume as a jet plane."}, {"version": "white-2", "text": "Usually, its cries are like quiet murmurs. If frightened, it shrieks at the same volume as a jet plane."}, {"version": "x", "text": "It usually murmurs but starts crying loudly if it senses danger. It stops when its ear covers are shut."}, {"version": "y", "text": "If it senses danger, it scares the foe by crying out with the volume of a jet-plane engine."}], "entryGameVersions": ["alpha-sapphire", "black", "black-2", "diamond", "emerald", "firered", "heartgold", "leafgreen", "omega-ruby", "pearl", "platinum", "ruby", "sapphire", "shield", "soulsilver", "sword", "white", "white-2", "x", "y"], "moveGameGroups": ["black-2-white-2", "black-white", "brilliant-diamond-shining-pearl", "colosseum", "diamond-pearl", "emerald", "firered-leafgreen", "heartgold-soulsilver", "omega-ruby-alpha-sapphire", "platinum", "ruby-sapphire", "sun-moon", "sword-shield", "ultra-sun-ultra-moon", "x-y", "xd"], "evolutionRows": [{"stage": 1, "name": "whismur"}, {"stage": 2, "name": "loudred"}, {"stage": 3, "name": "exploud"}]}